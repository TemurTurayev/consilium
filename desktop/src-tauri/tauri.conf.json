{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Consilium",
  "version": "0.1.0",
  "identifier": "dev.consilium.desktop",
  "build": {
    "frontendDist": "../../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm --prefix \"$(git rev-parse --show-toplevel)/ui\" run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Consilium",
        "width": 1120,
        "height": 780
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "appimage",
      "deb"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}